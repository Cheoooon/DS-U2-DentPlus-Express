<div class="max-w-xl mx-auto py-6 sm:px-6 lg:px-8">
  <div class="mb-4">
    <a href="/affiliates" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Volver al listado</a>
  </div>

  <div class="bg-white shadow sm:rounded-lg border border-gray-100 p-6">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Editar Datos de Afiliado</h2>

    {{#if error}}
      <div class="mb-4 rounded-md bg-red-50 p-4 border-l-4 border-red-400 text-sm font-medium text-red-800">{{error}}</div>
    {{/if}}

    <!-- El action apunta a tu ruta POST declarada: /affiliates/:id/edit -->
    <form action="/affiliates/{{affiliate.id}}/edit" method="POST" class="space-y-4">
      
      <!-- Campos de Nombre y Apellido alineados -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="firstName" class="block text-sm font-medium text-gray-700">Nombre</label>
          <input type="text" id="firstName" name="firstName" required value="{{affiliate.firstName}}" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
        </div>

        <div>
          <label for="lastName" class="block text-sm font-medium text-gray-700">Apellido</label>
          <input type="text" id="lastName" name="lastName" required value="{{affiliate.lastName}}" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
        </div>
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-gray-700">Correo Electrónico</label>
        <input type="email" id="email" name="email" required value="{{affiliate.email}}" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
      </div>

      <div>
        <label for="membershipId" class="block text-sm font-medium text-gray-700">Tipo de Membresía</label>
        <select id="membershipId" name="membershipId" required class="mt-1 block w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
          <option value="">Selecciona un nivel...</option>
          {{#each memberships}}
            <!-- Validamos la membresía actual usando el helper eq que registraste -->
            <option value="{{this.id}}" {{#if (eq this.id ../affiliate.membershipId)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>

      <div class="pt-4 flex justify-end space-x-3">
        <a href="/affiliates" class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">Cancelar</a>
        <button type="submit" class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700">Actualizar Cambios</button>
      </div>
    </form>
  </div>
</div>