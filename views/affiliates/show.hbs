<div class="max-w-3xl mx-auto py-6 sm:px-6 lg:px-8">
  <div class="mb-4">
    <a href="/affiliates" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Volver al listado</a>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-100">
    <div class="px-4 py-5 sm:px-6 flex justify-between items-center bg-gray-50">
      <div>
        <h3 class="text-lg leading-6 font-medium text-gray-900">Información del Afiliado</h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">Detalles personales y estado de la suscripción.</p>
      </div>
      
      <!-- Contenedor de acciones unificado y alineado -->
      <div class="flex items-center space-x-2">
        <a href="/affiliates/{{affiliate.id}}/edit" class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 shadow-sm">
            Editar
        </a>
        
        <a href="/affiliates/{{affiliate.id}}/delete" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 shadow-sm transition-colors">
            Eliminar
        </a>
      </div>
    </div>
    
    <div class="border-t border-gray-200 px-4 py-5 sm:p-0">
      <dl class="sm:divide-y divide-gray-200">
        <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Nombre completo</dt>
          <!-- Combinamos nombre y apellido del nuevo modelo -->
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">{{affiliate.firstName}} {{affiliate.lastName}}</dd>
        </div>
        
        <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Correo electrónico</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">{{affiliate.email}}</dd>
        </div>

        <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Nivel de Membresía</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                {{affiliate.membership.name}} 
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">
                {{affiliate.membership.discountPercentage}}% desc.
            </span>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Caja de Herramienta: Cálculo de Beneficios -->
  <div class="mt-6 bg-white shadow sm:rounded-lg border border-gray-100 p-6">
    <h3 class="text-md font-bold text-gray-900 mb-2">Simulador de Beneficios</h3>
    <p class="text-sm text-gray-500 mb-4">Calcula el descuento aplicable a este afiliado basado en su nivel de membresía actual ({{affiliate.membership.discountPercentage}}% de descuento).</p>
    
    <form action="/affiliates/{{affiliate.id}}/compute" method="POST" class="sm:flex sm:items-center space-y-3 sm:space-y-0 sm:space-x-4">
      <div class="w-full sm:max-w-xs">
        <label for="amount" class="sr-only">Monto Base</label>
        <div class="relative rounded-md shadow-sm">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <span class="text-gray-500 sm:text-sm">$</span>
          </div>
          <input type="number" name="amount" id="amount" required min="1" placeholder="Monto base de compra" class="block w-full pl-7 pr-3 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
        </div>
      </div>
      <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
        Calcular Descuento
      </button>
    </form>
  </div>
</div>