<div class="max-w-xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <a href="/affiliates/{{affiliate.id}}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Volver a la ficha de {{affiliate.firstName}}</a>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
    <div class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200">
      <h3 class="text-lg leading-6 font-bold text-gray-900">Resultado de la Simulación</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Beneficio calculado para {{affiliate.firstName}} {{affiliate.lastName}}.</p>
    </div>

    <div class="p-6 space-y-4 bg-white">
      <div class="flex justify-between text-sm text-gray-600">
        <span>Monto base solicitado:</span>
        <span class="font-mono font-semibold text-gray-900">${{calculation.originalAmount}}</span>
      </div>
      
      <div class="flex justify-between text-sm text-red-600 font-medium bg-red-50/50 rounded">
        <span>Descuento de membresía (-{{calculation.discountPercentage}}%):</span>
        <span class="font-mono">-${{calculation.discountValue}}</span>
      </div>

      <hr class="border-gray-200 my-2">
      
      <div class="flex justify-between items-center text-base font-bold text-gray-900 pt-2">
        <span>Total Neto a Cobrar:</span>
        <span class="font-mono text-2xl text-indigo-600">${{calculation.finalPrice}}</span>
      </div>
    </div>

    <div class="px-4 py-4 sm:px-6 bg-gray-50 border-t border-gray-200 flex justify-end">
      <a href="/affiliates/{{affiliate.id}}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
        Aceptar y Cerrar
      </a>
    </div>
  </div>
</div>