<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DentPlus - Gestión de Afiliados</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <link rel="icon" type="image/svg+xml" href="/asset/favicon.svg">
  <style>
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 9999px; }
    ::-webkit-scrollbar-thumb:hover { background-color: #94a3b8; }
  </style>
</head>
<body class="bg-gray-50 font-sans text-gray-900 flex flex-col h-screen w-full overflow-hidden">

  <nav class="bg-white border-b border-gray-200 shadow-sm w-full shrink-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <a href="/" class="flex-shrink-0 flex items-center gap-2">
            <span class="text-2xl font-black tracking-tight bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
              DentPlus
            </span>
          </a>
        </div>

        <div class="flex items-center gap-4">
          {{#if isAuthenticated}}
            <a href="/affiliates" class="text-sm font-medium text-gray-700 hover:text-indigo-600 transition-colors">
              Mis Afiliados
            </a>
            <span class="text-sm text-gray-400">|</span>
            <span class="text-sm font-semibold text-gray-800">
              Hola, {{currentUser}}
            </span>
            <a href="/logout" class="ml-2 inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-white bg-red-600 hover:bg-red-700 transition-colors">
              Cerrar Sesión
            </a>
          {{else}}
            <a href="/login" class="text-sm font-medium text-gray-700 hover:text-indigo-600 transition-colors">
              Iniciar Sesión
            </a>
            <a href="/register" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 transition-colors shadow-sm">
              Registrarse
            </a>
          {{/if}}
        </div>
      </div>
    </div>
  </nav>

  <main class="flex-grow w-full bg-gray-50 overflow-auto scrollbar-gutter-stable">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      {{{body}}}
    </div>
  </main>

  <footer class="bg-white border-t border-gray-200 py-4 text-center text-xs text-gray-500 w-full shrink-0 z-10">
    &copy; 2026 DentPlus. Todos los derechos reservados.
  </footer>

</body>
</html>