<%- include('../partials/header', { title: 'Eliminar afiliado' }) %>

<h1>Eliminar Afiliado</h1>
<a href="/afiliado/<%= patient.id %>">← Volver a la ficha</a>

<div style="margin-top: 20px; border: 1px solid red; padding: 20px; max-width: 400px; border-radius: 5px;">
    <h2 style="color: red; margin-top: 0;">¡Atención!</h2>
    <p>Estás a punto de eliminar permanentemente al siguiente afiliado:</p>
    
    <ul>
        <li><strong>Nombre:</strong> <%= patient.firstName %> <%= patient.lastName %></li>
        <li><strong>Email:</strong> <%= patient.email %></li>
    </ul>
    
    <p>¿Estás seguro de que deseas continuar? Esta acción no se puede deshacer.</p>
    
    <form action="/afiliado/<%= patient.id %>/eliminar" method="POST" style="margin-top: 20px;">
        <button type="submit" style="background-color: #ff4444; color: white; padding: 10px 15px; border: none; border-radius: 3px; cursor: pointer;">
            Sí, eliminar definitivamente
        </button>
    </form>
</div>
<%- include('../partials/footer') %>