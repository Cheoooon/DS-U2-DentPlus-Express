{
  "compilerOptions": {
    /* Opciones de Lenguaje y Entorno */
    "target": "ESNext", 
    "module": "NodeNext",
    "moduleResolution": "nodenext",

    /* Directorios */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Interoperabilidad */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Comprobación de Tipos (Type Checking) */
    "strict": true,
    "skipLibCheck": true,

    "allowSyntheticDefaultImports": true,
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
